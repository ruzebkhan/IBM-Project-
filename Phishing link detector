<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Simple Phishing Detector</title>
  <style>
    :root {
      --bg: #0f172a;
      --surface: #1e293b;
      --surface-strong: #334155;
      --text: #e2e8f0;
      --text-muted: #94a3b8;
      --accent: #38bdf8;
      --success: #22c55e;
      --warning: #f59e0b;
      --danger: #ef4444;
      font-family: Inter, system-ui, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background: radial-gradient(circle at top, rgba(56, 189, 248, 0.18), transparent 35%),
        linear-gradient(180deg, #0b1121 0%, #111827 100%);
      color: var(--text);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .container {
      width: min(760px, 100%);
      background: rgba(15, 23, 42, 0.96);
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 24px 80px rgba(15, 23, 42, 0.35);
    }

    h1 {
      margin: 0 0 10px;
      font-size: clamp(2rem, 3vw, 2.7rem);
      line-height: 1.05;
    }

    p.lead {
      margin: 0 0 28px;
      color: var(--text-muted);
      font-size: 1rem;
      line-height: 1.7;
    }

    .card {
      background: var(--surface);
      border-radius: 20px;
      padding: 24px;
      margin-top: 20px;
      border: 1px solid rgba(148, 163, 184, 0.1);
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: var(--text);
    }

    input[type="text"], textarea {
      width: 100%;
      border-radius: 14px;
      border: 1px solid rgba(148, 163, 184, 0.16);
      background: rgba(15, 23, 42, 0.9);
      color: var(--text);
      padding: 14px 16px;
      font-size: 1rem;
      outline: none;
      resize: vertical;
    }

    textarea {
      min-height: 120px;
    }

    .options {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 18px;
    }

    .option-button {
      appearance: none;
      border: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(15, 23, 42, 0.7);
      color: var(--text);
      padding: 12px 18px;
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.2s ease, border-color 0.2s ease;
    }

    .option-button.active {
      background: rgba(56, 189, 248, 0.12);
      border-color: rgba(56, 189, 248, 0.5);
      color: #cbd5e1;
    }

    .action-row {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    button {
      border: none;
      border-radius: 14px;
      background: linear-gradient(135deg, #38bdf8, #0ea5e9);
      color: #0f172a;
      font-weight: 700;
      padding: 14px 22px;
      cursor: pointer;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    button:hover {
      transform: translateY(-1px);
    }

    .result {
      margin-top: 22px;
      padding: 24px;
      border-radius: 20px;
      background: rgba(15, 23, 42, 0.85);
      border: 1px solid rgba(148, 163, 184, 0.12);
    }

    .result h2 {
      margin-top: 0;
      font-size: 1.25rem;
    }

    .result p {
      margin: 8px 0;
      line-height: 1.7;
      color: var(--text-muted);
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 8px 14px;
      font-weight: 700;
      letter-spacing: 0.01em;
    }

    .badge.safe { background: rgba(34, 197, 94, 0.15); color: #a7f3d0; }
    .badge.suspicious { background: rgba(245, 158, 11, 0.15); color: #fde68a; }
    .badge.phishing { background: rgba(239, 68, 68, 0.15); color: #fecdd3; }

    .hint-list {
      margin: 18px 0 0;
      padding-left: 20px;
      color: var(--text-muted);
    }

    .hint-list li {
      margin-bottom: 8px;
    }

    .footer {
      margin-top: 26px;
      color: var(--text-muted);
      font-size: 0.96rem;
      line-height: 1.6;
    }
  </style>
</head>
<body>
  <main class="container">
    <h1>Phishing Detector</h1>
    <p class="lead">Paste a URL or suspicious email content to quickly see whether it looks like phishing. This is a simple heuristic tool, not a substitute for security software.</p>

    <div class="card">
      <div class="options" role="radiogroup" aria-label="Input type selection">
        <button type="button" class="option-button active" id="urlMode">URL</button>
        <button type="button" class="option-button" id="textMode">Email / Message</button>
      </div>

      <div id="inputGroup">
        <label for="inputValue">Enter a URL</label>
        <input id="inputValue" type="text" placeholder="https://example.com/login" autocomplete="off" />
      </div>

      <div class="action-row">
        <button id="checkButton">Check for phishing</button>
        <span id="scoreLabel" class="badge safe">Ready</span>
      </div>

      <div id="result" class="result" hidden>
        <h2 id="resultTitle">Detection result</h2>
        <p id="resultMessage"></p>
        <ul id="resultList" class="hint-list"></ul>
      </div>
    </div>

    <p class="footer">Tip: Check actual sender addresses, avoid clicking unknown links, and keep your browser and antivirus up to date.</p>
  </main>

  <script>
    const urlMode = document.getElementById('urlMode');
    const textMode = document.getElementById('textMode');
    const inputGroup = document.getElementById('inputGroup');
    let inputValue = document.getElementById('inputValue');
    const checkButton = document.getElementById('checkButton');
    const result = document.getElementById('result');
    const resultTitle = document.getElementById('resultTitle');
    const resultMessage = document.getElementById('resultMessage');
    const resultList = document.getElementById('resultList');
    const scoreLabel = document.getElementById('scoreLabel');

    let mode = 'url';

    function setMode(newMode) {
      mode = newMode;
      urlMode.classList.toggle('active', mode === 'url');
      textMode.classList.toggle('active', mode === 'text');
      const label = mode === 'url' ? 'Enter a URL' : 'Paste suspicious email or message';
      const placeholder = mode === 'url' ? 'https://example.com/login' : 'Dear user, your account has been locked...';
      const inputField = mode === 'url'
        ? `<input id="inputValue" type="text" placeholder="${placeholder}" autocomplete="off" />`
        : `<textarea id="inputValue" placeholder="${placeholder}" autocomplete="off"></textarea>`;

      inputGroup.innerHTML = `
        <label for="inputValue">${label}</label>
        ${inputField}
      `;
      inputValue = document.getElementById('inputValue');
    }

    urlMode.addEventListener('click', () => setMode('url'));
    textMode.addEventListener('click', () => setMode('text'));

    function updateScoreLabel(text, type) {
      scoreLabel.textContent = text;
      scoreLabel.className = `badge ${type}`;
    }

    function isIpAddress(input) {
      return /^\d{1,3}(?:\.\d{1,3}){3}$/.test(input);
    }

    function getDomain(url) {
      try {
        const normalized = url.trim().replace(/^https?:\/\//i, '');
        return normalized.split('/')[0].split('?')[0];
      } catch {
        return '';
      }
    }

    function assessUrl(value) {
      const hints = [];
      const url = value.trim();
      const lowered = url.toLowerCase();
      const domain = getDomain(url);
      let score = 0;

      if (!url) {
        hints.push('Enter a URL before checking.');
        return {score, hints};
      }

      if (!/^https?:\/\//i.test(url)) {
        hints.push('Missing protocol. Phishing URLs often omit or fake HTTPS.');
        score += 2;
      }

      if (lowered.includes('@')) {
        hints.push('The URL contains an @ symbol, which can hide the real destination.');
        score += 3;
      }

      if (domain.includes('-') && domain.split('.').length > 2) {
        hints.push('A long or hyphenated domain may indicate an imitation site.');
        score += 2;
      }

      if (isIpAddress(domain) || /^\d{1,3}(?:\.\d{1,3}){3}/.test(domain)) {
        hints.push('The URL uses an IP address instead of a normal domain name.');
        score += 3;
      }

      if (url.length > 75) {
        hints.push('A very long URL often hides malicious redirection paths.');
        score += 1;
      }

      const suspiciousWords = ['login', 'secure', 'verify', 'account', 'update', 'banking', 'confirm', 'password', 'reset'];
      suspiciousWords.forEach(word => {
        if (lowered.includes(word)) {
          hints.push(`Contains the suspicious word: "${word}"`);
          score += 1;
        }
      });

      if (/\.exe$|\.scr$|\.zip$|\.rar$/i.test(url)) {
        hints.push('The link points to a file download rather than a website.');
        score += 3;
      }

      if (!domain || domain.length < 4) {
        hints.push('Unable to identify a valid domain.');
        score += 2;
      }

      if (score >= 6) {
        return {score, hints, verdict: 'phishing'};
      }
      if (score >= 3) {
        return {score, hints, verdict: 'suspicious'};
      }
      if (hints.length === 0) {
        hints.push('No obvious phishing patterns found, but always stay cautious.');
      }
      return {score, hints, verdict: 'safe'};
    }

    function assessText(value) {
      const hints = [];
      const text = value.trim();
      const lowered = text.toLowerCase();
      let score = 0;

      if (!text) {
        hints.push('Enter the suspicious text before checking.');
        return {score, hints};
      }

      const triggerWords = [
        'verify', 'password', 'account', 'bank', 'login', 'urgent', 'immediately', 'click here', 'reset', 'suspend', 'security alert', 'payment', 'update now'
      ];

      triggerWords.forEach(word => {
        if (lowered.includes(word)) {
          hints.push(`Contains the warning phrase: "${word}"`);
          score += 1;
        }
      });

      if (/https?:\/\//.test(text)) {
        hints.push('The text includes one or more links.');
        score += 2;
      }

      if (/\bdear (customer|user|member)\b/.test(lowered)) {
        hints.push('Generic greetings like "Dear customer" are common in phishing.');
        score += 1;
      }

      if (/\b(attach|attachment|invoice)\b/.test(lowered)) {
        hints.push('Mentions of attachments or invoices can be used to trick recipients.');
        score += 1;
      }

      if (/\b(account|payment|password)\b.*\b(verify|confirm|update|reset)\b/.test(lowered)) {
        hints.push('The message asks to verify or update sensitive account information.');
        score += 2;
      }

      if (score >= 7) {
        return {score, hints, verdict: 'phishing'};
      }
      if (score >= 4) {
        return {score, hints, verdict: 'suspicious'};
      }
      if (hints.length === 0) {
        hints.push('No strong phishing triggers found, but remain careful with unexpected requests.');
      }
      return {score, hints, verdict: 'safe'};
    }

    function showResult({verdict = 'safe', hints = []}) {
      result.hidden = false;
      if (verdict === 'phishing') {
        resultTitle.textContent = 'Likely phishing';
        resultMessage.textContent = 'This input shows multiple phishing indicators. Do not follow the link or share credentials.';
        result.classList.add('phishing');
        updateScoreLabel('Phishing', 'phishing');
      } else if (verdict === 'suspicious') {
        resultTitle.textContent = 'Potential phishing';
        resultMessage.textContent = 'The input has suspicious characteristics. Verify the sender before taking any action.';
        updateScoreLabel('Suspicious', 'suspicious');
      } else {
        resultTitle.textContent = 'Looks safer';
        resultMessage.textContent = 'No obvious phishing patterns were detected, but stay cautious with unknown content.';
        updateScoreLabel('Safe', 'safe');
      }

      resultList.innerHTML = hints.map(hint => `<li>${hint}</li>`).join('');
    }

    checkButton.addEventListener('click', () => {
      const value = inputValue.value || inputValue.textContent || '';
      const assessment = mode === 'url' ? assessUrl(value) : assessText(value);
      showResult(assessment);
    });
  </script>
</body>
</html>
